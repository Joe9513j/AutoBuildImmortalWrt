
config status 'status'

config config 'config'
	option enabled '1'
	option profile 'file:config.yaml'
	option start_delay '0'
	option scheduled_restart '0'
	option cron_expression '0 3 * * *'
	option test_profile '1'
	option mixin '1'
	option fast_reload '1'

