	option tun_mtu '9000'
	option tun_gso '1'
	option tun_gso_max_size '37280'
	option tun_endpoint_independent_nat '1'
	option dns_port '1053'
	option dns_mode 'fake-ip'
	option fake_ip_range '198.18.0.1/16'
